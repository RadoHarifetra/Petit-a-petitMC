{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Quote": {
      "title": "Quote",
      "description": "Sales quotation",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "QuoteItem" } },
        "status": { "type": "string", "enum": ["ORDERED", "SENT", "REJECTED"] },
        "totalProfit": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "items", "status"]
    },
    "QuoteItem": {
      "title": "Quote Item",
      "description": "Item within a quote",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "currency": { "type": "string", "enum": ["EUR", "USD", "CNY", "MGA"] },
        "salePrice": { "type": "number" },
        "profit": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Active or historical order",
      "type": "object",
      "properties": {
        "quoteId": { "type": "string" },
        "clientId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "QuoteItem" } },
        "status": { "type": "string", "enum": ["PREPARATION", "TRANSIT", "WAREHOUSE", "DELIVERED", "COLLECTED"] },
        "trackingNumber": { "type": "string" },
        "freightForwarder": { "type": "string" },
        "weight": { "type": "number" },
        "shippingType": { "type": "string", "enum": ["SEA", "AIR", "EXPRESS"] },
        "shippingCostMGA": { "type": "number" },
        "totalToPayMGA": { "type": "number" },
        "deliveryFeeMGA": { "type": "number" },
        "eta": { "type": "string", "format": "date-time" },
        "sentAt": { "type": "string", "format": "date-time" },
        "arrivedAt": { "type": "string", "format": "date-time" },
        "collectedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "status", "shippingType"]
    },
    "Settings": {
      "title": "Settings",
      "description": "App-wide logistics rates and configurations",
      "type": "object",
      "properties": {
        "seaRate": { "type": "number", "description": "USD fixed rate per shipment/unit if sea" },
        "airRatePerKg": { "type": "number", "description": "MGA per kg for Air" },
        "expressRatePerKg": { "type": "number", "description": "MGA per kg for Express" },
        "lastExchangeRates": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Forwarder": {
      "title": "Forwarder",
      "description": "Logistics partner with custom rates",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "seaRate": { "type": "number", "description": "USD per m3" },
        "airRate": { "type": "number", "description": "MGA per KG" },
        "expressRate": { "type": "number", "description": "MGA per KG" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "seaRate", "airRate", "expressRate"]
    }
  },
  "firestore": {
    "/clients": { "schema": "Client", "description": "Customer list" },
    "/quotes": { "schema": "Quote", "description": "Quotations" },
    "/orders": { "schema": "Order", "description": "Tracking and Warehouse orders" },
    "/settings/global": { "schema": "Settings", "description": "Global config" },
    "/forwarders": { "schema": "Forwarder", "description": "Logistics forwarders list" }
  }
}

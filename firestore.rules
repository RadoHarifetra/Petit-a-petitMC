rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PHASE 3: PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "radoh410@gmail.com";
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- PHASE 4: VALIDATION BLUEPRINTS ---

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && (data.email == null || (data.email is string && data.email.size() <= 100))
          && (data.phone == null || (data.phone is string && data.phone.size() <= 30))
          && data.labels is list && data.labels.size() <= 20
          && data.keys().hasAll(['name', 'labels'])
          && data.keys().size() >= 2;
    }

    function isValidQuoteItem(item) {
      return item.type is string && item.type.size() <= 100
          && item.purchasePrice is number && item.purchasePrice >= 0
          && item.salePrice is number && item.salePrice >= 0
          && item.currency in ['EUR', 'USD', 'CNY', 'MGA']
          && item.profit is number;
    }

    function isValidQuote(data) {
      return isValidId(data.clientId)
          && (!('forwarderId' in data) || data.forwarderId == null || data.forwarderId == "" || (data.forwarderId is string && data.forwarderId.size() <= 128))
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.status in ['ORDERED', 'SENT', 'REJECTED']
          && (!('totalProfit' in data) || data.totalProfit is number)
          && data.keys().hasAll(['clientId', 'items', 'status']);
    }

    function isValidOrder(data) {
      return isValidId(data.clientId)
          && (!('forwarderId' in data) || data.forwarderId == null || data.forwarderId == "" || (data.forwarderId is string && data.forwarderId.size() <= 128))
          && data.status in ['PREPARATION', 'TRANSIT', 'WAREHOUSE', 'DELIVERED', 'COLLECTED']
          && (!('shippingType' in data) || data.shippingType in ['SEA', 'AIR', 'EXPRESS'])
          && (!('weight' in data) || (data.weight is number && data.weight >= 0))
          && (!('shippingCostMGA' in data) || (data.shippingCostMGA is number && data.shippingCostMGA >= 0))
          && (!('totalToPayMGA' in data) || data.totalToPayMGA is number)
          && (!('deliveryFeeMGA' in data) || data.deliveryFeeMGA is number)
          && data.keys().hasAll(['clientId', 'status']);
    }

    function isValidForwarder(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.seaRate is number && data.seaRate >= 0
          && data.airRate is number && data.airRate >= 0
          && data.expressRate is number && data.expressRate >= 0
          && data.keys().hasAll(['name', 'seaRate', 'airRate', 'expressRate'])
          && data.keys().size() >= 4;
    }

    // --- PHASE 5: COLLECTION MATCHES ---

    match /clients/{clientId} {
      allow list: if isVerified();
      allow get: if isVerified();
      allow create: if isVerified() && isValidClient(incoming()) 
                     && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidClient(incoming())
                     && incoming().createdAt == existing().createdAt
                     && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'labels', 'updatedAt']))
                     && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow list: if isVerified();
      allow get: if isVerified();
      allow create: if isVerified() && isValidQuote(incoming())
                     && exists(/databases/$(database)/documents/clients/$(incoming().clientId))
                     && (!('forwarderId' in incoming()) || incoming().forwarderId == null || incoming().forwarderId == "" || exists(/databases/$(database)/documents/forwarders/$(incoming().forwarderId)))
                     && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidQuote(incoming())
                     && ( !('createdAt' in existing()) || incoming().createdAt == existing().createdAt )
                     && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['status', 'items', 'totalProfit', 'forwarderId', 'weight', 'shippingType', 'updatedAt', 'quoteId', 'clientId']))
                     && incoming().updatedAt == request.time;
      allow delete: if isVerified() && (isAdmin() || existing().status != 'ORDERED');
    }

    match /orders/{orderId} {
      allow list: if isVerified();
      allow get: if isVerified();
      allow create: if isVerified() && isValidOrder(incoming())
                     && exists(/databases/$(database)/documents/clients/$(incoming().clientId))
                     && (!('forwarderId' in incoming()) || incoming().forwarderId == null || incoming().forwarderId == "" || exists(/databases/$(database)/documents/forwarders/$(incoming().forwarderId)))
                     && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidOrder(incoming())
                     && ( !('createdAt' in existing()) || incoming().createdAt == existing().createdAt )
                     && (
                        isAdmin() || (
                          // Terminal lock: No updates if already COLLECTED
                          existing().status != 'COLLECTED' && (
                            // Action: Logistics Update
                            (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'trackingNumber', 'freightForwarder', 'forwarderId', 'weight', 'shippingType', 'shippingCostMGA', 'totalToPayMGA', 'eta', 'sentAt', 'arrivedAt', 'items', 'updatedAt', 'quoteId', 'clientId'])) ||
                            // Action: Collection
                            (incoming().status == 'COLLECTED' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'deliveryFeeMGA', 'totalToPayMGA', 'collectedAt', 'updatedAt']))
                          )
                        )
                     )
                     && incoming().updatedAt == request.time;
      allow delete: if isAdmin();
    }

    match /forwarders/{forwarderId} {
      allow list: if isVerified();
      allow get: if isVerified();
      allow create: if isVerified() && isValidForwarder(incoming())
                     && incoming().createdAt == request.time;
      allow update: if isVerified() && isValidForwarder(incoming())
                     && ( !('createdAt' in existing()) || incoming().createdAt == existing().createdAt )
                     && (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['name', 'seaRate', 'airRate', 'expressRate', 'updatedAt']))
                     && incoming().updatedAt == request.time;
      allow delete: if isVerified(); // Based on UI allowing deletion
    }

    match /settings/{settingId} {
      allow read: if isVerified();
      allow write: if isAdmin();
    }
  }
}
